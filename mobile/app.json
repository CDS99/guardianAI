{
  "expo": {
    "name": "Guardian",
    "slug": "guardian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardianai.theurbe",
      "buildNumber": "1",
      "appleTeamId": "JT4R2UQWM5",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Guardian usa la tua posizione per mostrarti le segnalazioni nel tuo quartiere e centrare la mappa dove ti trovi.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Guardian può inviare la tua posizione ai contatti fidati durante un SOS attivo e avvisarti quando rientri nelle zone salvate.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.guardianai.theurbe",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
